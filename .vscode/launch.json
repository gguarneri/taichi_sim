{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ponto WebGPU",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sim_webgpu.py",
            "console": "integratedTerminal",
            "args": "--config=${workspaceFolder}/ensaios/ponto/ponto.json"
        },
        {
            "name": "Ponto CuPy-conv",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sim_cupy_conv.py",
            "console": "integratedTerminal",
            "args": "--config=${workspaceFolder}/ensaios/ponto/ponto.json"
        },
        {
            "name": "Ponto CuPy-cuda",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sim_cupy_cuda.py",
            "console": "integratedTerminal",
            "args": "--config=${workspaceFolder}/ensaios/ponto/ponto.json"
        },
        {
            "name": "Ponto Numba",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sim_numba.py",
            "console": "integratedTerminal",
            "args": "--config=${workspaceFolder}/ensaios/ponto/ponto.json",
            "env": {"NUMBA_ENABLE_CUDASIM": "0"}
        },
        {
            "name": "Ponto CPU-broadcast",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sim_cpu_broadcast.py",
            "console": "integratedTerminal",
            "args": "--config=${workspaceFolder}/ensaios/ponto/ponto.json"
        },
        {
            "name": "Ponto CPU-conv",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sim_cpu_conv.py",
            "console": "integratedTerminal",
            "args": "--config=${workspaceFolder}/ensaios/ponto/ponto.json"
        }
    ]
}