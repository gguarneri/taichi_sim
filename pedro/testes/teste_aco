import numpy as np
import matplotlib.pyplot as plt

# Aço:
# Densidade (p): 7850 kg/m³
# Velocidade longitudinal (cp): 5.9 mm/micros
# Velocidade Transversal (cs): 3.2 mm/micros
p_aco = 7850
cp_aco = 5.9    
cs_aco = 3.2

# Água:
# Densidade (p): 1000 kg/m³
# Velocidade longitudinal (cp): 1.483 mm/micros
# Velocidade Transversal (cs): 0 mm/micros
p_agua = 1000
cp_agua = 1.483
cs_agua = 0

# Matrizes que simulam a peça de aço e suas propriedades.
matriz_densidade = np.zeros((700, 550), dtype=np.float32) # Type definition 'float32'
matriz_vtrans = np.zeros((700, 550), dtype=np.float32) # Type definition 'float32'
matriz_vlong = np.zeros((700, 550), dtype=np.float32) # Type definition 'float32'

# Simulando falta de água na parte superior da peça de aço, entre o transutor e a peça.

matriz_densidade[:,:] = p_aco
matriz_densidade[:, 0:49] = p_agua

matriz_vtrans[:,:] = cs_aco
matriz_vtrans[:, 0:49] = cs_agua

matriz_vlong[:,:] = cp_aco
matriz_vlong[:, 0:49] = cp_agua

# Simulando um defeito circular de água dentro do aço
y, x = np.ogrid[0:700, 0:550] # Cria uma grade de coordenadas para as linhas (y) e colunas (x)
mascara = (x - 450)**2 + (y - 300)**2 <= 10**2 # Cria uma máscara booleana para os pixels dentro do círculo definido pelo centro (cx, cy) e raio (r)

# Define os pixels dentro do círculo como água 
matriz_densidade[mascara] = p_agua
matriz_vtrans[mascara] = cs_agua 
matriz_vlong[mascara] = cp_agua 

#plt.imshow(matriz_densidade, cmap='viridis')  # escolha de cores melhor
#plt.colorbar(label='Densidade')
#plt.title('Mapa de Densidade')
#plt.xlabel('Colunas')
#plt.ylabel('Linhas')
#plt.show()   


np.save('rho_aco.npy', matriz_densidade)
np.save('cs_aco.npy', matriz_vtrans)
np.save('cp_aco.npy', matriz_vlong)






